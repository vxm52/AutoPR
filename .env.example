# Set to true to use MockLLMClient instead of hitting the real API.
# Useful for building and testing the pipeline locally without credentials.
USE_MOCK_LLM=true

# GitHub authentication
GITHUB_TOKEN=...
GITHUB_REPO_OWNER=...
GITHUB_REPO_NAME=...

# Course-provided LLM
LLM_API_KEY=...
LLM_BASE_URL=...

# Local paths
REPO_CLONE_PATH=/tmp/autopr_repos
INDEX_PATH=/tmp/autopr_indexes
